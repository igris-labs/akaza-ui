{
  "name": "akaza-ui",
  "version": "0.0.1",
  "description": "Vue-native headless UI primitives — accessible, unstyled, composable.",
  "type": "module",
  "main": "./dist/akaza-ui.cjs",
  "module": "./dist/akaza-ui.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/akaza-ui.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/akaza-ui.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm typecheck && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.build.json",
    "lint": "oxlint . && eslint .",
    "lint:fix": "oxlint . --fix && eslint . --fix",
    "format": "oxfmt",
    "format:fix": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vueuse/core": "^13.1.0"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.10.3",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.7",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.37.0",
    "eslint-plugin-oxlint": "^1.51.0",
    "globals": "^17.4.0",
    "jsdom": "^26.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^0.16.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.7",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue3",
    "headless",
    "ui",
    "accessible",
    "a11y",
    "composable",
    "unstyled",
    "primitives"
  ],
  "license": "MIT"
}
